# Database
DATABASE_URL=postgresql://simplifica:simplifica123@localhost:5432/simplifica

# JWT
JWT_SECRET=replace-with-a-random-secret-with-at-least-64-characters-and-high-entropy
JWT_EXPIRES_IN=7d

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# DOE-TO API
DOE_API_URL=https://diariooficial.to.gov.br/api.json
DOE_ALLOWED_HOSTS=diariooficial.to.gov.br
DOE_SYNC_CRON=0 8 * * 1-5
HTTP_TIMEOUT_MS=15000
PDF_DOWNLOAD_TIMEOUT_MS=30000
OPENROUTER_TIMEOUT_MS=30000
SUMMARY_MAX_CONTENT_CHARS=120000

# App
NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Docs (optional basic auth for non-production)
DOCS_AUTH_USER=
DOCS_AUTH_PASSWORD=
