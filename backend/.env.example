# Database
DATABASE_URL=postgresql://simplifica:simplifica123@localhost:5432/simplifica

# JWT
JWT_SECRET=replace-with-a-random-secret-with-at-least-64-characters-and-high-entropy
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10
PASSWORD_RESET_URL=http://localhost:3000/reset-password

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@simplifica.local
SMTP_FROM_NAME=Simplifica

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=xiaomi/mimo-v2-pro
OPENROUTER_FALLBACK_MODEL=arcee-ai/trinity-large-preview:free,stepfun/step-3.5-flash:free #,nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001
# OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-120b,anthropic/claude-3-haiku
OPENROUTER_PROVIDER_SORT_BY=throughput
OPENROUTER_PROVIDER_SORT_PARTITION=none
OPENROUTER_MAX_TOKENS=5000

# DOE-TO API
DOE_API_URL=https://diariooficial.to.gov.br/api.json
DOE_ALLOWED_HOSTS=diariooficial.to.gov.br,doe.to.gov.br
DOE_SYNC_CRON=0 8 * * 1-5
OPENROUTER_TIMEOUT_MS=90000
OPENROUTER_RATE_LIMIT_DELAY_MS=12000

# App
NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
OPS_ADMIN_EMAILS=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Administrador
